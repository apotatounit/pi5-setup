# Copy to config.env and fill in. Never commit the real file.
# All values are read by 01-flash.sh and rendered into custom.toml.

# --- identity ---
PI_HOSTNAME="pi5-dev"
PI_USER="anton"

# --- ssh ---
# Remote login is **SSH public-key only** (see custom.toml). Use the private key matching SSH_PUBKEY_PATH
# (same path without `.pub`). Example:
#   ssh -o IdentitiesOnly=yes -i ~/.ssh/id_ed25519 ${PI_USER}@10.42.0.1
# `.last_password` after flash is for local console / recovery only, not SSH.
SSH_PUBKEY_PATH="$HOME/.ssh/id_ed25519.pub"

# --- wifi ---
WIFI_SSID="YourNetwork"
WIFI_PASSWORD="YourWifiPassword"
WIFI_COUNTRY="US"

# --- wifi access point on the Pi (fallback: join this AP from phone/laptop, then SSH) ---
# Used by: make wifi-ap   and   make bootstrap (runs 05-wifi-ap.sh after 03-bootstrap.sh).
WIFI_AP_ENABLE=1
# WIFI_AP_SSID defaults to ${PI_HOSTNAME}-ap if unset (letters, digits, hyphen only for boot-only path)
WIFI_AP_SSID=""
WIFI_AP_PASSWORD="changeMe!!"   # min 8 chars (WPA2-PSK)

# --- rescue: AP without Ethernet or working infra Wi-Fi (staged on SD at flash time) ---
# When 1: custom.toml has NO [wlan] client; first boot finishes stock firstboot + custom.toml, reboots,
# then second boot runs a one-shot that installs a NetworkManager hotspot (join SSID, SSH 10.42.0.1).
# Requires WIFI_AP_PASSWORD; AP SSID defaults to ${PI_HOSTNAME}-ap (ASCII safe).
WIFI_AP_BOOT_ONLY=0

# --- locale ---
TIMEZONE="America/New_York"
KEYMAP="us"

# --- image ---
IMG_URL="https://downloads.raspberrypi.com/raspios_lite_arm64_latest"
IMG_SHA_URL="https://downloads.raspberrypi.com/raspios_lite_arm64_latest.sha256"
