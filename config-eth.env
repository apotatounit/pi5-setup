# Ethernet-only headless config for 01-flash-eth.sh
# Copy to config-eth.env (already done) and fill in SSH_PUBKEY_PATH if different.

# --- identity ---
PI_HOSTNAME="lab-pi5"
PI_USER="pi"

# --- ssh ---
# Public key injected into authorized_keys on first boot.
# Password auth is also enabled so you can get in if the key fails — disable later.
SSH_PUBKEY_PATH="$HOME/.ssh/id_ed25519.pub"

# --- ethernet static IP ---
ETH_IP="192.168.100.91"
ETH_PREFIX="24"                  # subnet prefix length (24 = /24 = 255.255.255.0)
ETH_GATEWAY="192.168.100.1"
ETH_DNS="192.168.100.1 8.8.8.8" # space-separated

# --- locale ---
TIMEZONE="America/Santiago"
KEYMAP="us"

# --- image ---
IMG_URL="https://downloads.raspberrypi.com/raspios_lite_arm64_latest"
IMG_SHA_URL="https://downloads.raspberrypi.com/raspios_lite_arm64_latest.sha256"
